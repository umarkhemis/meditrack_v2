# ─────────────────────────────────────────────────────────────────────────────
# MediTrack — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-very-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-domain.com

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/meditrack?sslmode=require

# ── Timezone ──────────────────────────────────────────────────────────────────
TIME_ZONE=Africa/Kampala

# ── CORS — add your frontend URL ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# ── Twilio ────────────────────────────────────────────────────────────────────
# Leave all blank to use built-in delivery (no external SMS)
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+12015551234        # Your Twilio SMS number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio WhatsApp sandbox/approved number
TWILIO_USE_WHATSAPP=False               # Set True to send via WhatsApp instead of SMS

# Twilio Webhook — set this URL in Twilio Console → Phone Numbers → Messaging
# https://your-backend.com/api/sms/webhook/

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL patients will receive in SMS check-in links
FRONTEND_URL=https://your-frontend-domain.com
